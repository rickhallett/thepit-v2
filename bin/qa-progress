#!/usr/bin/env python3
"""
qa-progress — Query and update the QA master checklist.

Usage:
    qa-progress                              # summary dashboard
    qa-progress list                         # list all checks
    qa-progress list --phase phase2-ui       # filter by phase
    qa-progress list --category human-taste  # filter by category
    qa-progress list --status pending        # filter by status
    qa-progress list --blocking              # only blocking items
    qa-progress list --human                 # all human-* categories
    qa-progress mark <id> pass|fail|skip "notes"   # mark a check
    qa-progress run-gate <branch>            # run gate on branch, auto-mark
    qa-progress phase <phase>                # phase detail summary

Categories: automated, code-review, human-flow, human-visual, human-taste, human-security
Status:     pending, pass, fail, skip, na
"""

import sys
import os
import re
import subprocess
from datetime import datetime, timezone
from pathlib import Path

# ── YAML parser (no external deps) ─────────────────────────
# Minimal parser sufficient for our flat-list checklist schema.
# Does NOT handle arbitrary YAML — only the qa-master-checklist format.

CHECKLIST_PATH = Path(__file__).resolve().parent.parent / "docs" / "internal" / "weaver" / "qa-master-checklist.yaml"


def parse_checklist(path: Path) -> list[dict]:
    """Parse checks from the YAML file. Returns list of check dicts."""
    checks = []
    current = None
    in_checks = False

    with open(path, "r") as f:
        for line in f:
            stripped = line.rstrip()

            if stripped == "checks:":
                in_checks = True
                continue

            if not in_checks:
                continue

            # New check item
            if re.match(r"^  - id: ", stripped):
                if current:
                    checks.append(current)
                current = {"id": stripped.split("id: ")[1].strip().strip('"')}
                continue

            if current is None:
                continue

            # Parse key: value pairs
            m = re.match(r"^    (\w[\w_]*): (.+)$", stripped)
            if m:
                key, val = m.group(1), m.group(2).strip()
                # Handle special values
                if val == "null":
                    current[key] = None
                elif val == "true":
                    current[key] = True
                elif val == "false":
                    current[key] = False
                elif val.startswith("[") and val.endswith("]"):
                    # Simple list parsing
                    inner = val[1:-1].strip()
                    if inner:
                        current[key] = [x.strip().strip('"') for x in inner.split(",")]
                    else:
                        current[key] = []
                elif val.startswith('"') and val.endswith('"'):
                    current[key] = val[1:-1]
                else:
                    current[key] = val

    if current:
        checks.append(current)

    return checks


def write_checklist(path: Path, checks: list[dict]) -> None:
    """Update check statuses in-place in the YAML file."""
    # Build a map of id -> check for quick lookup
    check_map = {c["id"]: c for c in checks}

    lines = path.read_text().splitlines()
    result = []
    current_id = None

    for line in lines:
        stripped = line.rstrip()

        # Track which check we're in
        m = re.match(r"^  - id: (.+)$", stripped)
        if m:
            current_id = m.group(1).strip().strip('"')

        # Replace status, verified_by, timestamp, notes for current check
        if current_id and current_id in check_map:
            check = check_map[current_id]
            if re.match(r"^    status: ", stripped):
                result.append(f"    status: {check.get('status', 'pending')}")
                continue
            if re.match(r"^    verified_by: ", stripped):
                vb = check.get("verified_by")
                result.append(f"    verified_by: {vb if vb else 'null'}")
                continue
            if re.match(r"^    timestamp: ", stripped):
                ts = check.get("timestamp")
                ts_val = f'"{ts}"' if ts else "null"
                result.append(f"    timestamp: {ts_val}")
                continue
            if re.match(r"^    notes: ", stripped):
                notes = check.get("notes")
                if notes:
                    result.append(f'    notes: "{notes}"')
                else:
                    result.append("    notes: null")
                continue

        result.append(line.rstrip())

    path.write_text("\n".join(result) + "\n")


# ── Display helpers ─────────────────────────────────────────

COLORS = {
    "pass": "\033[32m",    # green
    "fail": "\033[31m",    # red
    "pending": "\033[33m", # yellow
    "skip": "\033[90m",    # gray
    "na": "\033[90m",      # gray
    "reset": "\033[0m",
    "bold": "\033[1m",
    "dim": "\033[2m",
}

# Disable colors if not a terminal
if not sys.stdout.isatty():
    COLORS = {k: "" for k in COLORS}


def status_icon(status: str) -> str:
    icons = {"pass": "✓", "fail": "✗", "pending": "○", "skip": "–", "na": "·"}
    color = COLORS.get(status, "")
    return f"{color}{icons.get(status, '?')}{COLORS['reset']}"


def summary(checks: list[dict]) -> None:
    """Print dashboard summary."""
    total = len(checks)
    by_status = {}
    for c in checks:
        s = c.get("status", "pending")
        by_status[s] = by_status.get(s, 0) + 1

    blocking = [c for c in checks if c.get("blocking") and c.get("status") == "pending"]
    failed = [c for c in checks if c.get("status") == "fail"]

    passed = by_status.get("pass", 0)
    pct = (passed / total * 100) if total else 0

    print(f"\n{COLORS['bold']}QA MASTER CHECKLIST — noopit{COLORS['reset']}")
    print(f"{'─' * 50}")
    print(f"  Total checks:  {total}")
    for status in ["pass", "fail", "pending", "skip", "na"]:
        count = by_status.get(status, 0)
        if count > 0:
            print(f"  {status_icon(status)} {status:<10} {count:>3}")
    print(f"{'─' * 50}")
    print(f"  Progress:      {COLORS['bold']}{passed}/{total} ({pct:.0f}%){COLORS['reset']}")
    print(f"  Blocking:      {len(blocking)} items pending")
    if failed:
        print(f"  {COLORS['fail']}FAILURES:      {len(failed)} items{COLORS['reset']}")
    print()

    # Per-phase summary
    phases = []
    seen = set()
    for c in checks:
        p = c.get("phase", "unknown")
        if p not in seen:
            phases.append(p)
            seen.add(p)

    print(f"  {'Phase':<24} {'Pass':>5} {'Fail':>5} {'Pend':>5} {'Total':>6}")
    print(f"  {'─' * 48}")
    for phase in phases:
        phase_checks = [c for c in checks if c.get("phase") == phase]
        p_pass = sum(1 for c in phase_checks if c.get("status") == "pass")
        p_fail = sum(1 for c in phase_checks if c.get("status") == "fail")
        p_pend = sum(1 for c in phase_checks if c.get("status") == "pending")
        p_total = len(phase_checks)
        fail_mark = f" {COLORS['fail']}✗{COLORS['reset']}" if p_fail else ""
        print(f"  {phase:<24} {p_pass:>5} {p_fail:>5} {p_pend:>5} {p_total:>6}{fail_mark}")

    # Per-category summary
    print()
    categories = []
    seen_cat = set()
    for c in checks:
        cat = c.get("category", "unknown")
        if cat not in seen_cat:
            categories.append(cat)
            seen_cat.add(cat)

    print(f"  {'Category':<24} {'Pass':>5} {'Fail':>5} {'Pend':>5} {'Total':>6}")
    print(f"  {'─' * 48}")
    for cat in categories:
        cat_checks = [c for c in checks if c.get("category") == cat]
        c_pass = sum(1 for c in cat_checks if c.get("status") == "pass")
        c_fail = sum(1 for c in cat_checks if c.get("status") == "fail")
        c_pend = sum(1 for c in cat_checks if c.get("status") == "pending")
        c_total = len(cat_checks)
        print(f"  {cat:<24} {c_pass:>5} {c_fail:>5} {c_pend:>5} {c_total:>6}")

    print()


def list_checks(checks: list[dict], filters: dict) -> None:
    """List checks with optional filters."""
    filtered = checks

    if filters.get("phase"):
        filtered = [c for c in filtered if c.get("phase") == filters["phase"]]
    if filters.get("category"):
        filtered = [c for c in filtered if c.get("category") == filters["category"]]
    if filters.get("status"):
        filtered = [c for c in filtered if c.get("status") == filters["status"]]
    if filters.get("blocking"):
        filtered = [c for c in filtered if c.get("blocking")]
    if filters.get("human"):
        filtered = [c for c in filtered if c.get("category", "").startswith("human-")]

    if not filtered:
        print("  No checks match the given filters.")
        return

    current_phase = None
    for c in filtered:
        phase = c.get("phase", "unknown")
        if phase != current_phase:
            current_phase = phase
            print(f"\n{COLORS['bold']}  ── {phase} ──{COLORS['reset']}")

        sid = c.get("id", "???")
        status = c.get("status", "pending")
        desc = c.get("desc", "")
        cat = c.get("category", "")
        blocking = " [BLOCKING]" if c.get("blocking") else ""
        notes = c.get("notes") or ""

        icon = status_icon(status)
        cat_short = cat.replace("human-", "h:").replace("code-review", "cr").replace("automated", "auto")

        print(f"  {icon} {COLORS['dim']}{sid:<10}{COLORS['reset']} [{cat_short:<8}] {desc}{COLORS['fail']}{blocking}{COLORS['reset']}")
        if notes and status == "fail":
            print(f"    {COLORS['dim']}→ {notes}{COLORS['reset']}")

    print()
    total = len(filtered)
    passed = sum(1 for c in filtered if c.get("status") == "pass")
    print(f"  {passed}/{total} checks shown ({total - passed} remaining)")
    print()


def mark_check(checks: list[dict], check_id: str, new_status: str, notes: str) -> list[dict]:
    """Mark a check with new status and notes."""
    valid = {"pass", "fail", "skip", "na"}
    if new_status not in valid:
        print(f"  Error: status must be one of {valid}")
        sys.exit(1)

    found = False
    for c in checks:
        if c["id"] == check_id:
            c["status"] = new_status
            c["verified_by"] = "operator"
            c["timestamp"] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
            if notes:
                c["notes"] = notes
            found = True
            print(f"  {status_icon(new_status)} {check_id} → {new_status}")
            if notes:
                print(f"    {COLORS['dim']}→ {notes}{COLORS['reset']}")
            break

    if not found:
        print(f"  Error: check '{check_id}' not found")
        sys.exit(1)

    return checks


def run_gate(checks: list[dict], branch: str) -> list[dict]:
    """Run gate on a branch and auto-mark the gate check."""
    print(f"\n  Running gate on {branch}...")

    # Switch to branch
    result = subprocess.run(
        ["git", "checkout", branch],
        capture_output=True, text=True, cwd=CHECKLIST_PATH.parent.parent.parent.parent
    )
    if result.returncode != 0:
        print(f"  Error: could not checkout {branch}: {result.stderr}")
        return checks

    # Run gate
    gate_result = subprocess.run(
        ["pnpm", "run", "typecheck"],
        capture_output=True, text=True, cwd=CHECKLIST_PATH.parent.parent.parent.parent
    )
    typecheck_ok = gate_result.returncode == 0

    lint_result = subprocess.run(
        ["pnpm", "run", "lint"],
        capture_output=True, text=True, cwd=CHECKLIST_PATH.parent.parent.parent.parent
    )
    lint_ok = lint_result.returncode == 0

    test_result = subprocess.run(
        ["pnpm", "run", "test"],
        capture_output=True, text=True, cwd=CHECKLIST_PATH.parent.parent.parent.parent
    )
    test_ok = test_result.returncode == 0

    # Extract test counts from output
    test_output = test_result.stdout + test_result.stderr
    pass_match = re.search(r"(\d+) passed", test_output)
    skip_match = re.search(r"(\d+) skipped", test_output)
    pass_count = int(pass_match.group(1)) if pass_match else 0
    skip_count = int(skip_match.group(1)) if skip_match else 0

    gate_ok = typecheck_ok and lint_ok and test_ok
    now = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

    # Find and mark gate checks for this branch
    for c in checks:
        if c.get("phase") == branch and c.get("category") == "automated":
            if "gate green" in c.get("desc", "").lower() or "Gate green" in c.get("desc", ""):
                c["status"] = "pass" if gate_ok else "fail"
                c["verified_by"] = "gate"
                c["timestamp"] = now
                c["notes"] = f"typecheck:{'ok' if typecheck_ok else 'FAIL'} lint:{'ok' if lint_ok else 'FAIL'} test:{'ok' if test_ok else 'FAIL'} ({pass_count} pass, {skip_count} skip)"
            elif "test count" in c.get("desc", "").lower() or "Test count" in c.get("desc", ""):
                # Extract expected minimum from desc
                min_match = re.search(r">= (\d+)", c.get("desc", ""))
                if min_match:
                    expected_min = int(min_match.group(1))
                    actual = pass_count + skip_count
                    c["status"] = "pass" if actual >= expected_min else "fail"
                    c["verified_by"] = "gate"
                    c["timestamp"] = now
                    c["notes"] = f"actual: {actual} (expected >= {expected_min})"

    print(f"  Gate: {'PASS' if gate_ok else 'FAIL'}")
    print(f"  typecheck: {'✓' if typecheck_ok else '✗'}  lint: {'✓' if lint_ok else '✗'}  test: {'✓' if test_ok else '✗'}")
    print(f"  Tests: {pass_count} pass, {skip_count} skip")
    print()

    return checks


def phase_detail(checks: list[dict], phase: str) -> None:
    """Show detailed view of a phase."""
    phase_checks = [c for c in checks if c.get("phase") == phase]
    if not phase_checks:
        print(f"  No checks for phase '{phase}'")
        return

    total = len(phase_checks)
    passed = sum(1 for c in phase_checks if c.get("status") == "pass")
    failed = sum(1 for c in phase_checks if c.get("status") == "fail")
    blocking_pending = sum(1 for c in phase_checks if c.get("blocking") and c.get("status") == "pending")

    ready = failed == 0 and blocking_pending == 0

    print(f"\n{COLORS['bold']}Phase: {phase}{COLORS['reset']}")
    print(f"{'─' * 50}")
    print(f"  Progress: {passed}/{total} ({passed/total*100:.0f}%)")
    print(f"  Blocking pending: {blocking_pending}")
    print(f"  Failures: {failed}")
    if ready:
        print(f"  {COLORS['bold']}{COLORS.get('pass', '')}READY FOR SIGNOFF{COLORS['reset']}")
    else:
        print(f"  {COLORS['bold']}{COLORS.get('fail', '')}NOT READY{COLORS['reset']}")
    print()

    # Group by category
    by_cat = {}
    for c in phase_checks:
        cat = c.get("category", "unknown")
        by_cat.setdefault(cat, []).append(c)

    for cat, items in by_cat.items():
        print(f"  {COLORS['bold']}{cat}{COLORS['reset']}")
        for c in items:
            icon = status_icon(c.get("status", "pending"))
            blocking = " !" if c.get("blocking") else ""
            print(f"    {icon} {c['id']}{blocking} — {c.get('desc', '')}")
        print()


# ── CLI ─────────────────────────────────────────────────────

def main():
    if not CHECKLIST_PATH.exists():
        print(f"  Error: checklist not found at {CHECKLIST_PATH}")
        sys.exit(1)

    checks = parse_checklist(CHECKLIST_PATH)
    args = sys.argv[1:]

    if not args:
        summary(checks)
        return

    cmd = args[0]

    if cmd == "list":
        filters = {}
        i = 1
        while i < len(args):
            if args[i] == "--phase" and i + 1 < len(args):
                filters["phase"] = args[i + 1]
                i += 2
            elif args[i] == "--category" and i + 1 < len(args):
                filters["category"] = args[i + 1]
                i += 2
            elif args[i] == "--status" and i + 1 < len(args):
                filters["status"] = args[i + 1]
                i += 2
            elif args[i] == "--blocking":
                filters["blocking"] = True
                i += 1
            elif args[i] == "--human":
                filters["human"] = True
                i += 1
            else:
                i += 1
        list_checks(checks, filters)

    elif cmd == "mark":
        if len(args) < 3:
            print("  Usage: qa-progress mark <id> pass|fail|skip [notes]")
            sys.exit(1)
        check_id = args[1]
        new_status = args[2]
        notes = args[3] if len(args) > 3 else ""
        checks = mark_check(checks, check_id, new_status, notes)
        write_checklist(CHECKLIST_PATH, checks)

    elif cmd == "run-gate":
        if len(args) < 2:
            print("  Usage: qa-progress run-gate <branch>")
            sys.exit(1)
        branch = args[1]
        checks = run_gate(checks, branch)
        write_checklist(CHECKLIST_PATH, checks)

    elif cmd == "phase":
        if len(args) < 2:
            print("  Usage: qa-progress phase <phase-name>")
            sys.exit(1)
        phase_detail(checks, args[1])

    elif cmd == "walkthrough":
        # Show only human checks, ordered by priority for Operator's walkthrough
        print(f"\n{COLORS['bold']}OPERATOR'S WALKTHROUGH — Human verification items{COLORS['reset']}")
        print(f"{'─' * 60}")
        print(f"  Items are ordered: blocking first, then by phase merge order.\n")
        human_checks = [c for c in checks if c.get("category", "").startswith("human-") and c.get("status") == "pending"]
        # Sort: blocking first, then by phase
        phase_order = {"phase2-ui": 0, "phase4-economy": 1, "phase5-discovery": 2, "deploy": 3, "spec-gap": 4}
        human_checks.sort(key=lambda c: (0 if c.get("blocking") else 1, phase_order.get(c.get("phase", ""), 99)))

        for c in human_checks:
            icon = status_icon("pending")
            cat = c.get("category", "").replace("human-", "")
            blocking = f" {COLORS['fail']}[BLOCKING]{COLORS['reset']}" if c.get("blocking") else ""
            notes = c.get("notes") or ""
            print(f"  {icon} {c['id']} [{cat}] {c.get('desc', '')}{blocking}")
            if notes:
                print(f"    {COLORS['dim']}hint: {notes}{COLORS['reset']}")

        print(f"\n  {len(human_checks)} human checks remaining")
        print(f"  Mark with: bin/qa-progress mark <id> pass|fail \"notes\"")
        print()

    elif cmd == "--help" or cmd == "-h":
        print(__doc__)

    else:
        print(f"  Unknown command: {cmd}")
        print("  Commands: list, mark, run-gate, phase, walkthrough, --help")
        sys.exit(1)


if __name__ == "__main__":
    main()
